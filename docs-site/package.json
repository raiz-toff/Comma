{
  "name": "comma-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for Comma, built with Fumadocs.",
  "scripts": {
    "vendor": "rm -rf docs-src && cp -r ../docs docs-src && rm -rf docs-src/images && cp ../CHANGELOG.md changelog-src.md",
    "sync": "node scripts/sync-content.mjs",
    "predev": "npm run sync",
    "prebuild": "npm run sync",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.3",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.3",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
